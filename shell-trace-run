#!/usr/bin/env python3
"""Print shell trace invocations for each family and mode.

These are the commands run when SHELLENV_USE_SHELL_TRACE=1.
- bash/tcsh: shell -x [mode flags] -c :
- zsh: zsh -o SOURCE_TRACE -x [mode flags] -c :  (PS4=+%N:%i> in env)
"""
from __future__ import annotations

import sys
from pathlib import Path

# Run from project root
PROJECT_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(PROJECT_ROOT))

from shellenv.modes import INVOCATION_MODES, mode_to_args  # noqa: E402

SHELLS = ("bash", "zsh", "tcsh")
EXIT_CMD = ":"


def main() -> None:
    for family in SHELLS:
        for mode in INVOCATION_MODES:
            args = mode_to_args(family, mode, exit_cmd=EXIT_CMD)
            flags = " ".join(args)
            if family == "zsh":
                # zsh needs -o SOURCE_TRACE for proper file discovery
                print(f"/bin/zsh -o SOURCE_TRACE {flags}")
            else:
                print(f"/bin/{family} -x {flags}")


if __name__ == "__main__":
    main()
