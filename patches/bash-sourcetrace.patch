+/* Announce each sourced file (zsh SOURCE_TRACE analog).  Always emitted when
+   a file is read via _evalfile(); lines match shellenv parse_bash_trace. */
 void
+xtrace_source_trace (filename)
+     const char *filename;
+{
+  if (filename == 0)
+    return;
+  CHECK_XTRACE_FP;
+  fprintf (xtrace_fp, "+0.000000 %s:1 <sourcetrace>\n", filename);
+  fflush (xtrace_fp);
+}
+
+void
 xtrace_fdchk (fd)
      int fd;
